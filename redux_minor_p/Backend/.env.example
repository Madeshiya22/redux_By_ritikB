# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/redux_minor_p
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/redux_minor_p

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_this_in_production_with_strong_key
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_this_in_production_with_strong_key
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Configuration (optional - for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
